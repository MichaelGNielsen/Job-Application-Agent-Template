# === Gemini AI Konfiguration ===
# Hent din API nøgle her: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Model valg: 'gemini-1.5-pro' eller 'gemini-1.5-flash'
# GEMINI_MODEL=gemini-1.5-pro

# Verbose output for debugging 
# * VERBOSE="-v" : Viser kun de store milepæle.
# * VERBOSE="-vv" : Viser detaljer om research og filer.
# * VERBOSE="-vvv" : Viser de rå kommandoer og debug info.
# * VERBOSE="-vvvv" : Viser udsnit af de rå prompts og svar.
# * VERBOSE="-vvvvv" : Viser ALT (Fuldstændige prompts og svar).

VERBOSE="-vvvvv"
